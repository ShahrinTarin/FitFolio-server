# DB Configuration
DB_USER=your_db_username_here
DB_PASS=your_db_password_here

# Local MongoDB URI (for Docker) 
# Set this to override Atlas connection
MONGODB_URI=mongodb://your_db_username_here:your_db_password_here@mongodb:27017/fitFolio?authSource=admin

# JWT
JWT_SECRET_KEY=your_jwt_secret_here

# Payment Gateway (Stripe)
STRIPE_SK_KEY=your_stripe_key_here

# App Performance and Environment
PORT=3000
NODE_ENV=development
